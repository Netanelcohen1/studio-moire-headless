---
const year = new Date().getFullYear();
---
<footer class="site-footer" transition:persist="site-footer">
  <div class="max-w-6xl mx-auto px-6 py-16 grid grid-cols-1 md:grid-cols-4 gap-10">
    <div class="flex flex-col gap-3 md:col-span-2 max-w-prose">
      <span class="font-display text-xl text-ink">Studio Moire</span>
      <p class="text-sm">Studio Moire — Casablanca. Cloth, light, and the frame between them. Every garment is photographed beside its fabric samples before the model steps in.</p>
      <address class="not-italic text-sm mt-2 flex flex-col gap-1">
        <a href="mailto:hello@studio-moire.example" class="hover:text-accent">hello@studio-moire.example</a>
        <a href="tel:+212542344674" class="hover:text-accent">+212 54 2344 6744</a>
        <span>56 Lantern Court, Casablanca 1044, Morocco</span>
        <span class="text-mute">Tuesday–Saturday, 10:00–18:00</span>
      </address>
      <div class="flex gap-4 mt-2 text-sm">
        <a href="https://instagram.example/studiomoire" rel="me noopener" class="hover:text-accent" aria-label="Studio Moire on Instagram">Instagram</a>
        <a href="https://tiktok.example/@studiomoire" rel="me noopener" class="hover:text-accent" aria-label="Studio Moire on TikTok">TikTok</a>
      </div>
    </div>

    <nav aria-label="Footer">
      <h2 class="font-display text-sm text-ink uppercase tracking-wider mb-3">Explore</h2>
      <ul class="flex flex-col gap-2 text-sm">
        <li><a href="/portfolio" class="hover:text-accent">Portfolio</a></li>
        <li><a href="/book" class="hover:text-accent">Book a shoot</a></li>
        <li><a href="/about" class="hover:text-accent">About</a></li>
        <li><a href="/faq" class="hover:text-accent">FAQ</a></li>
        <li><a href="/contact" class="hover:text-accent">Contact</a></li>
        <li><a href="/account" class="hover:text-accent">My account</a></li>
      </ul>
    </nav>

    <nav aria-label="Legal">
      <h2 class="font-display text-sm text-ink uppercase tracking-wider mb-3">Legal</h2>
      <ul class="flex flex-col gap-2 text-sm">
        <li><a href="/privacy" class="hover:text-accent">Privacy Policy</a></li>
        <li><a href="/terms" class="hover:text-accent">Terms &amp; Conditions</a></li>
      </ul>
    </nav>
  </div>

  <div class="max-w-6xl mx-auto px-6 pb-10 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 text-xs">
    <p>© {year} Studio Moire. All rights reserved.</p>
    <p>
      <a href="https://www.wix.com/lp-en/headless" rel="noopener" class="hover:text-accent">Powered by Wix Headless</a>
    </p>
  </div>
</footer>
