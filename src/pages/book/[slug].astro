---
// src/pages/book/[slug].astro — SSR service detail (SEO) + client-side booking flow.
// One dir deep inside src/pages (book/) → import with ../../ to reach src/.
//
// SSRs the service info for SEO, then mounts the booking UI as a
// client:only="react" island (availability + booking are timezone/session-
// specific — never SSR them). The island runs the flow: AvailabilityCalendar →
// BookingForm → bookingDriver.book() → hosted checkout (paid) or place order
// (free/offline) → /booking-confirmation.
import Layout from '../../layouts/Layout.astro';
import SeoTags from '../../components/SeoTags.astro';
import ServiceBookingFlow from '../../components/ServiceBookingFlow';
import { services } from '@wix/bookings';
import { forms } from '@wix/forms';
import { auth } from '@wix/essentials';

const BOOKING_APP_ID = '13d21c63-b5ec-5912-8397-c3a5ddb27a97';
const { slug } = Astro.params;

// Carried from the catalog when the site has >1 location (absent here — single
// location — and on deep links; the picker then defaults to the service's first).
const reqUrl = new URL(Astro.request.url);
const locationId = reqUrl.searchParams.get('locationId') ?? undefined;

let service: any = null;
try {
  // Ambient SSR via @wix/essentials. Single service by slug: the .eq() builder
  // chain on mainSlug.name + appId (the form the @wix/bookings SDK expects).
  const result = await auth
    .elevate(services.queryServices)({ conditionalFields: ['STAFF_MEMBER_DETAILS'] })
    .eq('mainSlug.name', slug)
    .eq('appId', BOOKING_APP_ID)
    .limit(1)
    .find();
  service = result.items?.[0] ?? null;
} catch (err) {
  console.error(`[book/${slug}] detail query failed:`, err);
}

if (!service) return Astro.redirect('/book', 302);

// Booking-form SCHEMA — the form belongs to the service (service.form._id) in
// the bookings namespace. Read it server-side and pass the field list to the
// island. Keep each field's `target` — that is the key createBooking expects in
// formSubmission. Render only fields with a recognized string componentType
// (TEXT_INPUT/PHONE_INPUT/DROPDOWN); skip complex object-valued fields (e.g. a
// multi-line ADDRESS) — sending a string for them fails createBooking with
// "must be object". Only first_name/last_name/email are enforced, so skipping
// optional complex fields is safe.
let formFields: any[] = [];
try {
  const formId = service.form?._id;
  if (formId) {
    const res: any = await auth.elevate(forms.getForm)(formId);
    const form = res?.form ?? res;
    const RENDERABLE = ['TEXT_INPUT', 'PHONE_INPUT', 'DROPDOWN'];
    formFields = (form?.formFields ?? [])
      .filter(
        (f: any) =>
          f.fieldType === 'INPUT' &&
          !f.hidden &&
          RENDERABLE.includes(f.inputOptions?.stringOptions?.componentType),
      )
      .map((f: any) => {
        const opts = f.inputOptions;
        const str = opts?.stringOptions;
        const label =
          str?.textInputOptions?.label ??
          str?.dropdownOptions?.label ??
          str?.phoneInputOptions?.label ??
          '';
        return {
          label,
          target: opts?.target ?? '',
          required: opts?.required ?? false,
          componentType: str?.componentType ?? 'TEXT_INPUT',
          identifier: f.identifier ?? '',
          options: str?.dropdownOptions?.options?.map((o: any) => ({
            value: o.value ?? o.label ?? '',
            label: o.label ?? o.value ?? '',
          })),
        };
      });
  }
} catch (err) {
  console.error(`[book/${slug}] booking form schema failed:`, err);
}

const formatPrice = (p: any): string | undefined => {
  if (!p || p.rateType === 'NO_FEE') return undefined;
  if (p.rateType === 'FIXED' && p.fixed?.price) {
    const { value, currency } = p.fixed.price;
    if (!value) return undefined;
    try {
      return new Intl.NumberFormat('en-US', { style: 'currency', currency: currency ?? 'USD' }).format(Number(value));
    } catch {
      return `${value} ${currency ?? ''}`.trim();
    }
  }
  return undefined;
};
const price = formatPrice(service.payment);
const duration = service.schedule?.availabilityConstraints?.sessionDurations?.[0] ?? 60;
const imageUrl = service.media?.mainMedia?.image?.url ?? service.media?.items?.[0]?.image?.url;
const serviceName = service.name ?? 'Service';
const seoTags = service.seoData?.tags ?? [];

// Staff for the optional staff picker — carried via STAFF_MEMBER_DETAILS. Each
// entry is { staffMemberId, name } (staffMemberId IS the resource id). Shown only
// when >1; empty/absent → "any staff member" (the ANY_RESOURCE fallback).
const staffMembers = service.staffMemberDetails?.staffMembers ?? [];

// Business locations the service is offered at — sourced from queryLocations()
// (the site's real business locations, whose ids the availability engine
// recognizes), intersected with the service's own location ids, so a
// multi-location service scopes availability to one location (no duplicate
// per-location slots). Single-location site → resolves to one entry.
let serviceLocations: { _id: string; name?: string }[] = [];
try {
  const locResult: any = await auth.elevate(services.queryLocations)();
  const businessLocations = locResult?.businessLocations?.locations ?? [];
  const serviceLocationIds = new Set(
    (service.locations ?? [])
      .filter((l: any) => (l.type ?? 'BUSINESS') === 'BUSINESS')
      .map((l: any) => l.business?._id ?? l._id)
      .filter(Boolean),
  );
  serviceLocations = businessLocations
    .filter((l: any) => serviceLocationIds.has(l._id))
    .map((l: any) => ({ _id: l._id, name: l.business?.name ?? 'Location' }));
} catch (err) {
  console.error(`[book/${slug}] queryLocations failed:`, err);
}
---
<Layout title={serviceName} description={service.tagLine ?? service.description} hasSeoTags={seoTags.length > 0}>
  <SeoTags tags={seoTags} slot="head" />
  <section class="max-w-3xl mx-auto px-6 py-16">
    <a href="/book" class="inline-block text-sm text-mute hover:text-ink mb-8">← All shoots</a>

    {imageUrl && (
      <img src={imageUrl} alt={serviceName} class="w-full h-64 object-cover rounded-md border border-border mb-8" />
    )}

    <div class="flex flex-col gap-4 mb-12">
      <hr class="editorial-rule w-16 ml-0" />
      <h1 class="font-display text-4xl md:text-5xl leading-tight">{serviceName}</h1>
      {service.tagLine && <p class="text-lg text-mute leading-relaxed max-w-prose">{service.tagLine}</p>}
      <div class="flex items-center gap-4 text-sm text-mute">
        <span>{duration} min</span>
        {price && <span class="text-ink font-medium">{price}</span>}
      </div>
      {service.description && <p class="text-ink leading-relaxed max-w-prose">{service.description}</p>}
      <p class="text-sm text-mute">No payment is taken until you confirm the selected option.</p>
    </div>

    <section class="border-t border-rule pt-12">
      <h2 class="font-display text-3xl leading-tight mb-8">Book this shoot</h2>
      <ServiceBookingFlow
        service={service}
        serviceName={serviceName}
        serviceType={service.type ?? 'APPOINTMENT'}
        fields={formFields}
        staffMembers={staffMembers}
        locations={serviceLocations}
        locationId={locationId}
        client:only="react"
      />
    </section>
  </section>
</Layout>
