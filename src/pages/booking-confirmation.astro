---
// src/pages/booking-confirmation.astro — post-booking confirmation.
//
// Renders from the redirect query params (service name + start date) the booking
// step passes through. The Wix-hosted checkout returns here after a paid booking;
// a free / pay-in-person booking lands here directly. Do not re-fetch a stranger's
// booking from this public page — show what the flow passed in.
import Layout from '../layouts/Layout.astro';

const serviceName = Astro.url.searchParams.get('service') ?? 'your shoot';
const startDateParam = Astro.url.searchParams.get('startDate');
const formattedDate = startDateParam
  ? new Date(startDateParam).toLocaleString('en-US', {
      weekday: 'long', month: 'long', day: 'numeric', hour: '2-digit', minute: '2-digit',
    })
  : null;
---
<Layout title="Booking confirmed" description="Your shoot with Studio Moire is confirmed.">
  <section class="max-w-prose mx-auto px-6 py-24 text-center">
    <div class="w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-8"
         style="background-color: var(--color-accent);" aria-hidden="true">
      <span class="text-2xl" style="color: var(--color-ink);">✓</span>
    </div>
    <hr class="editorial-rule w-16 mx-auto mb-6" />
    <h1 class="font-display text-4xl md:text-5xl leading-tight mb-4">Thank you for booking</h1>

    {
      formattedDate ? (
        <p class="text-lg text-mute leading-relaxed mb-8">
          Your <strong class="text-ink">{serviceName}</strong> is <strong class="text-ink">confirmed</strong> for{' '}
          <strong class="text-ink">{formattedDate}</strong>. We've sent the details to your email.
        </p>
      ) : (
        <p class="text-lg text-mute leading-relaxed mb-8">
          Your booking for <strong class="text-ink">{serviceName}</strong> is <strong class="text-ink">confirmed</strong>. We've sent the details to your email.
        </p>
      )
    }

    <div class="flex flex-col gap-4 items-center">
      <a href="/book" class="btn-primary text-sm px-6 py-3">Book another shoot</a>
      <a href="/" class="text-sm text-mute hover:text-ink">Return home</a>
    </div>
  </section>
</Layout>
