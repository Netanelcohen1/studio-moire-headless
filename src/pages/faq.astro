---
import Layout from '../layouts/Layout.astro';
import { getFaq } from '../lib/cms';

const faqs = await getFaq();

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.question,
    acceptedAnswer: { "@type": "Answer", text: f.answer },
  })),
};
---
<Layout
  title="FAQ"
  description="Answers about booking, timing, changes, location, and mobile access at Studio Moire in Casablanca."
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(faqJsonLd)} slot="head" />

  <section class="max-w-6xl mx-auto px-6 pt-16 pb-8">
    <p class="kicker text-sm uppercase tracking-[0.18em] text-rule">FAQ</p>
    <h1 class="font-display font-bold leading-[1.05] mt-3" style="font-size: clamp(2rem, 4.5vw, 3.75rem);">Read answers</h1>
    <p class="text-lg text-mute max-w-prose mt-4">Pricing, timing, access, and preparation — the questions we're asked most.</p>
  </section>

  <section class="max-w-6xl mx-auto px-6 pb-24">
    <div class="container-reading flex flex-col gap-3">
      {faqs.map((f, i) => (
        <details class="faq-item border border-border rounded-md bg-paper-warm" open={i === 0}>
          <summary class="cursor-pointer list-none flex items-center justify-between gap-4 p-5 font-display text-xl">
            {f.question}
            <span class="faq-mark text-rule" aria-hidden="true">+</span>
          </summary>
          <div class="px-5 pb-5 text-mute leading-relaxed">{f.answer}</div>
        </details>
      ))}
    </div>

    <div class="container-reading mt-10 text-center">
      <p class="text-mute">Still have a question?</p>
      <div class="flex gap-4 justify-center mt-3">
        <a href="/contact" class="btn-secondary">Ask a question</a>
        <a href="/book" class="btn-primary">Book a shoot</a>
      </div>
    </div>
  </section>

  <style>
    .faq-item summary::-webkit-details-marker { display: none; }
    .faq-item[open] .faq-mark { transform: rotate(45deg); }
    .faq-mark { display: inline-block; transition: transform 200ms ease; font-size: 1.5rem; line-height: 1; }
    @media (prefers-reduced-motion: reduce) { .faq-mark { transition: none; } }
  </style>
</Layout>
